#!/usr/bin/env bash

# Config tool to manage and update shell configuration
# Used to manage my dotfiles - general config
# These are stored in the config repo.
# Tool also managed modules installed. ?
# Tool also used to manage toolkit itself.
#	-> Moving this responsibility to the toolkit tool.
#
# Try keep as little config as possible in the regular configuration files. (.zshrc)
# This is because various systems have customised configuration.
# It is easier to manage if the configuration is sourced from another file
# than trying to resolve conflicts manually each time.
#
# This tool should really change so its responsibility
# is applying configuration profiles. That is, configure applications
# with user specific settings and customization.
# The tools themselves should come from toolkit.
#
# I'm thinking a workflow like:
# - Update tools using toolkit.
#	-> Includes this config tool
# - Update and apply profile configuration using config tool.
#
# The separation of concerns enables installing tools via the toolkit without
# requiring all of the profile information config would provide.
# The enables using tools and scripts on endpoints without needing
# to use the same dotfiles everywhere. config would not always be necessary.

# The repo names are in order of detection.
# Some systems use dotfiles.git others use config.git.

__private_config_git () {
	/usr/bin/git --git-dir="$CONFIG_REPO_PATH" --work-tree="$HOME" "${@:1}"
}

# To bootstrap config, simply copy this script and execute "config init"
__private_config_init () {
	# Clone git repo into home directory	
	
	# Don't show untracked files
	__private_config_git config --local status.showUntrackedFiles no

}

__private_config_version() {
	local REPO_DIR="$CONFIG_REPO_PATH"

	local GIT_SHA
	GIT_SHA=$(git -C "$REPO_DIR" --work-tree="$HOME" rev-parse HEAD)

	local COMMIT_DATE
	COMMIT_DATE=$(git -C "$REPO_DIR" --work-tree="$HOME" log -1 --format="%cd" --date=short)

	# 1. Count how many commits origin/main is ahead of local HEAD
	local BEHIND=""
	local STATUS=""
	BEHIND=$(git -C "$REPO_DIR" --work-tree="$HOME" rev-list --count HEAD..origin/main 2>/dev/null)

	if [ -n "$BEHIND" ] && [ "$BEHIND" -gt 0 ]; then
		STATUS=" - Update Available ($BEHIND new commits)"
	fi

	# 2. Check for local modifications
	local MODIFIED=""
	if [ -n "$(git -C "$REPO_DIR" --work-tree="$HOME" status --porcelain)" ]; then
		MODIFIED=" (Modified Locally)"
	fi

	echo "Config Version: $GIT_SHA [$COMMIT_DATE]$MODIFIED$STATUS"
}

__private_config_check_updates() {
	local REPO_DIR="$CONFIG_REPO_PATH"

	echo "Checking for updates..."
	# Fetch updates synchronously since the user explicitly asked for it
	if ! git -C "$REPO_DIR" --work-tree="$HOME" fetch origin 2>/dev/null; then
		echo "Error: Could not connect to remote repository."
		return 1
	fi

	# Check how many commits we are behind
	local BEHIND
	BEHIND=$(git -C "$REPO_DIR" --work-tree="$HOME" rev-list --count HEAD..@\{u\} 2>/dev/null)

	if [ -n "$BEHIND" ] && [ "$BEHIND" -gt 0 ]; then
		echo "An update is available! You are behind by $BEHIND commit(s)."
		echo "Run 'git -C $REPO_DIR pull' to update."
	else
		echo "Config is up to date."
	fi
}

__private_config_upgrade() {
	local REPO_DIR="$CONFIG_REPO_PATH"

	echo "Upgrading config..."

	# 1. Use git -C to pull from origin main without changing your current terminal directory
	if git -C "$REPO_DIR" --work-tree="$HOME" pull origin main; then
		echo "Successfully upgraded to the latest version!"
	else
		echo "Error: Upgrade failed. Please check your network connection or local changes."
		return 1
	fi
}

config () {
	case "$1" in
		"git")
			__private_config_git "${@:2}"
			;;
		"init")
			__private_config_init
			;;
		"version")
			__private_config_version
			;;
		"update")
			__private_config_check_updates
			;;
		"upgrade")
			__private_config_upgrade
			;;
		*)
			echo "Config tool. Configuration repo: $CONFIG_REPO_PATH"
			echo "Usage: config git <command>"
			;;
	esac
}

config "$@"
